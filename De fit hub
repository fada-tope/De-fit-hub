<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>D'Fit Hub</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:url("background.jpg") center center/cover no-repeat;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
}

.overlay{
    position:fixed;
    inset:0;
    background:rgba(0,0,0,.65);
}

.card{
    position:relative;
    z-index:1;
    width:360px;
    text-align:center;
    color:white;
    background:rgba(255,255,255,.12);
    backdrop-filter:blur(12px);
    border-radius:20px;
    padding:30px;
}

h1{
    font-size:36px;
    margin-bottom:10px;
}

p{
    margin-bottom:25px;
    color:#ddd;
}

.btn{
    display:block;
    margin:15px 0;
    padding:15px;
    border-radius:12px;
    text-decoration:none;
    font-size:18px;
    font-weight:bold;
    transition:.3s;
}

.btn:hover{
    transform:scale(1.05);
}

.whatsapp{
    background:#25D366;
    color:white;
}

.tiktok{
    background:#000;
    color:white;
}

.snapchat{
    background:#FFFC00;
    color:black;
}

footer{
    margin-top:20px;
    color:#ccc;
    font-size:14px;
}
</style>
</head>

<body>

<div class="overlay"></div>

<div class="card">

<h1>D'Fit Hub</h1>

<p>Fit Your Style 👕</p>

<a class="btn whatsapp"
href="https://wa.me/2347075846461"
target="_blank">
📱 Chat on WhatsApp
</a>

<a class="btn tiktok"
href="https://www.tiktok.com/@dfit.hub"
target="_blank">
🎵 Follow on TikTok
</a>

<a class="btn snapchat"
href="https://www.snapchat.com/add/papslatony"
target="_blank">
👻 Add on Snapchat
</a>

<footer>
Premium Style • Affordable Prices
</footer>

</div>

</body>
</html>
